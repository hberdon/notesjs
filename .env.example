# ── Supabase (frontend / Vite) ───────────────────────────────
# From: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ── Google OAuth (local Supabase CLI only) ───────────────────
# Referenced by supabase/config.toml via env(). For PRODUCTION,
# set these in the Supabase Dashboard instead:
#   Authentication → Sign In / Providers → Google
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=your-google-oauth-client-id
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=your-google-oauth-client-secret